<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- namespace 속성은 해당 매퍼파일을 연결할 매퍼클래스(DAO) 설정(패키지포함) -->
<mapper namespace="kr.co.sboard.dao.ArticleDAO">

    <insert id="insert">
        INSERT INTO article SET
        type='free',
        title=#{title},
        content=#{content},
        file=#{file},
        writer=#{writer},
        regip=#{regip},
        wdate=NOW();

    </insert>

    <select id="select">
    </select>

    <select id="selectAll">
        SELECT
            a.*,
            u.nick
        FROM article a
        JOIN user u ON a.writer=u.userid
        ORDER BY a.ano DESC
        LIMIT #{pageRequestDTO.start}, 10;
    </select>

    <select id="selectCountAll">
        SELECT COUNT(*) FROM article;
    </select>

    <update id="update">
    </update>

    <delete id="delete">
    </delete>

</mapper>